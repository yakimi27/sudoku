<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Dark Theme Color Palette -->
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
            <!-- Base Colors -->
            <Color x:Key="SudokuBackgroundColor">#1F1F1F</Color>
            <Color x:Key="SudokuSurfaceColor">#2D2D2D</Color>
            <Color x:Key="SudokuBorderColor">#404040</Color>
            <Color x:Key="SudokuTextColor">#FFFFFF</Color>
            <Color x:Key="SudokuTextSecondaryColor">#A6A6A6</Color>

            <!-- Cell States -->
            <Color x:Key="CellEmptyColor">#252525</Color>
            <Color x:Key="CellGivenColor">#3A3A3A</Color>
            <Color x:Key="CellFilledColor">#252525</Color>
            <Color x:Key="CellErrorColor">#4A2122</Color>

            <!-- Interactive States -->
            <Color x:Key="CellSelectedColor">#0078D4</Color>
            <Color x:Key="CellHighlightColor">#1E3A5F</Color>
            <Color x:Key="BlockSeparatorColor">#FFFFFF</Color>
            <Color x:Key="CellBorderColor">#404040</Color>

            <!-- Accent Colors -->
            <Color x:Key="AccentColor">#0078D4</Color>
            <Color x:Key="SuccessColor">#107C10</Color>
            <Color x:Key="WarningColor">#FFB900</Color>
            <Color x:Key="ErrorColor">#F17378</Color>

            <!-- Brushes -->
            <SolidColorBrush x:Key="SudokuBackgroundBrush" Color="{StaticResource SudokuBackgroundColor}"/>
            <SolidColorBrush x:Key="SudokuSurfaceBrush" Color="{StaticResource SudokuSurfaceColor}"/>
            <SolidColorBrush x:Key="SudokuBorderBrush" Color="{StaticResource SudokuBorderColor}"/>
            <SolidColorBrush x:Key="SudokuTextBrush" Color="{StaticResource SudokuTextColor}"/>
            <SolidColorBrush x:Key="SudokuTextSecondaryBrush" Color="{StaticResource SudokuTextSecondaryColor}"/>

            <SolidColorBrush x:Key="CellEmptyBrush" Color="{StaticResource CellEmptyColor}"/>
            <SolidColorBrush x:Key="CellGivenBrush" Color="{StaticResource CellGivenColor}"/>
            <SolidColorBrush x:Key="CellFilledBrush" Color="{StaticResource CellFilledColor}"/>
            <SolidColorBrush x:Key="CellErrorBrush" Color="{StaticResource CellErrorColor}"/>

            <SolidColorBrush x:Key="CellSelectedBrush" Color="{StaticResource CellSelectedColor}"/>
            <SolidColorBrush x:Key="CellHighlightBrush" Color="{StaticResource CellHighlightColor}"/>
            <SolidColorBrush x:Key="BlockSeparatorBrush" Color="{StaticResource BlockSeparatorColor}"/>
            <SolidColorBrush x:Key="CellBorderBrush" Color="{StaticResource CellBorderColor}"/>

            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
            <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
            <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
            <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
