<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Sudoku.Presentation.Views.Controls.TimerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border
        Background="#F0F0F0"
        CornerRadius="8"
        Padding="16,12">
        <StackPanel Orientation="Horizontal" Spacing="12">
            <SymbolIcon Symbol="Clock"/>
            <TextBlock
                Text="{Binding ElapsedTime, Converter={StaticResource TimeSpanToStringConverter}}"
                FontSize="24"
                FontWeight="Bold"
                VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>
