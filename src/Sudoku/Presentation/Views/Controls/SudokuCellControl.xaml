<?xml version=1.0 encoding=utf-8?>
<UserControl
    x:Class=Sudoku.Presentation.Views.Controls.SudokuCellControl
    xmlns=http://schemas.microsoft.com/winfx/2006/xaml/presentation
    xmlns:x=http://schemas.microsoft.com/winfx/2006/xaml>

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source=ms-appx:///Presentation/Resources/Styles/CellStyles.xaml/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid
        Width=60
        Height=60
        Background={Binding State, Converter={StaticResource CellStateToColorConverter}}
        BorderBrush={ThemeResource CellBorderBrush}
        BorderThickness=1>

        <VisualStateManager.VisualStateGroups>
            <!-- Selection State -->
            <VisualStateGroup x:Name=SelectionStates>
                <VisualState x:Name=Unselected/>
                <VisualState x:Name=Selected>
                    <Storyboard>
                        <ObjectAnimationUsingKeyFrames
                            Storyboard.TargetName=SelectionBorder
                            Storyboard.TargetProperty=BorderBrush>
                            <DiscreteObjectKeyFrame KeyTime=0:0:0.1 Value={ThemeResource CellSelectedBrush}/>
                        </ObjectAnimationUsingKeyFrames>
                    </Storyboard>
                </VisualState>
            </VisualStateGroup>

            <!-- Highlight State -->
            <VisualStateGroup x:Name=HighlightStates>
                <VisualState x:Name=Normal/>
                <VisualState x:Name=Highlighted>
                    <Storyboard>
                        <ObjectAnimationUsingKeyFrames
                            Storyboard.TargetName=BackgroundRectangle
                            Storyboard.TargetProperty=Fill>
                            <DiscreteObjectKeyFrame KeyTime=0:0:0.1 Value={ThemeResource CellHighlightBrush}/>
                        </ObjectAnimationUsingKeyFrames>
                    </Storyboard>
                </VisualState>
            </VisualStateGroup>

            <!-- Error State -->
            <VisualStateGroup x:Name=ErrorStates>
                <VisualState x:Name=NoError/>
                <VisualState x:Name=HasError>
                    <Storyboard>
                        <ObjectAnimationUsingKeyFrames
                            Storyboard.TargetName=BackgroundRectangle
                            Storyboard.TargetProperty=Fill>
                            <DiscreteObjectKeyFrame KeyTime=0:0:0.1 Value={ThemeResource CellErrorBrush}/>
                        </ObjectAnimationUsingKeyFrames>
                    </Storyboard>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Rectangle
            x:Name=BackgroundRectangle
            Fill={ThemeResource CellEmptyBrush}/>

        <Border x:Name=SelectionBorder BorderThickness=3 BorderBrush=Transparent/>

        <Grid Padding=2>
            <!-- Large value display -->
            <TextBlock
                x:Name=ValueText
                Text={Binding Value}
                Style={StaticResource CellValueTextStyle}
                Visibility={Binding Value, Converter={StaticResource ValueToVisibilityConverter}}/>

            <!-- Notes grid (3x3) -->
            <Grid x:Name=NotesGrid Visibility={Binding Notes, Converter={StaticResource NotesVisibilityConverter}}>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width=*/>
                    <ColumnDefinition Width=*/>
                    <ColumnDefinition Width=*/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height=*/>
                    <RowDefinition Height=*/>
                    <RowDefinition Height=*/>
                </Grid.RowDefinitions>

                <!-- Note digits 1-9 -->
                <TextBlock Grid.Row=0 Grid.Column=0 Text=1 Style={StaticResource NoteDigitTextStyle} Visibility={Binding Notes, Converter={StaticResource NoteSetToVisibilityConverter}, ConverterParameter=1}/>
                <TextBlock Grid.Row=0 Grid.Column=1 Text=2 Style={StaticResource NoteDigitTextStyle} Visibility={Binding Notes, Converter={StaticResource NoteSetToVisibilityConverter}, ConverterParameter=2}/>
                <TextBlock Grid.Row=0 Grid.Column=2 Text=3 Style={StaticResource NoteDigitTextStyle} Visibility={Binding Notes, Converter={StaticResource NoteSetToVisibilityConverter}, ConverterParameter=3}/>

                <TextBlock Grid.Row=1 Grid.Column=0 Text=4 Style={StaticResource NoteDigitTextStyle} Visibility={Binding Notes, Converter={StaticResource NoteSetToVisibilityConverter}, ConverterParameter=4}/>
                <TextBlock Grid.Row=1 Grid.Column=1 Text=5 Style={StaticResource NoteDigitTextStyle} Visibility={Binding Notes, Converter={StaticResource NoteSetToVisibilityConverter}, ConverterParameter=5}/>
                <TextBlock Grid.Row=1 Grid.Column=2 Text=6 Style={StaticResource NoteDigitTextStyle} Visibility={Binding Notes, Converter={StaticResource NoteSetToVisibilityConverter}, ConverterParameter=6}/>

                <TextBlock Grid.Row=2 Grid.Column=0 Text=7 Style={StaticResource NoteDigitTextStyle} Visibility={Binding Notes, Converter={StaticResource NoteSetToVisibilityConverter}, ConverterParameter=7}/>
                <TextBlock Grid.Row=2 Grid.Column=1 Text=8 Style={StaticResource NoteDigitTextStyle} Visibility={Binding Notes, Converter={StaticResource NoteSetToVisibilityConverter}, ConverterParameter=8}/>
                <TextBlock Grid.Row=2 Grid.Column=2 Text=9 Style={StaticResource NoteDigitTextStyle} Visibility={Binding Notes, Converter={StaticResource NoteSetToVisibilityConverter}, ConverterParameter=9}/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
