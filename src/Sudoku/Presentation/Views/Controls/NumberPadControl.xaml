<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Sudoku.Presentation.Views.Controls.NumberPadControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Orientation="Vertical" Spacing="8">
        <TextBlock Text="Number Pad" FontSize="14" FontWeight="SemiBold" TextAlignment="Center"/>

        <!-- Numbers 1-9 -->
        <Grid ColumnSpacing="4" RowSpacing="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Row="0" Grid.Column="0" Content="1" HorizontalAlignment="Stretch" Command="{Binding SetValueCommand}" CommandParameter="1"/>
            <Button Grid.Row="0" Grid.Column="1" Content="2" HorizontalAlignment="Stretch" Command="{Binding SetValueCommand}" CommandParameter="2"/>
            <Button Grid.Row="0" Grid.Column="2" Content="3" HorizontalAlignment="Stretch" Command="{Binding SetValueCommand}" CommandParameter="3"/>

            <Button Grid.Row="1" Grid.Column="0" Content="4" HorizontalAlignment="Stretch" Command="{Binding SetValueCommand}" CommandParameter="4"/>
            <Button Grid.Row="1" Grid.Column="1" Content="5" HorizontalAlignment="Stretch" Command="{Binding SetValueCommand}" CommandParameter="5"/>
            <Button Grid.Row="1" Grid.Column="2" Content="6" HorizontalAlignment="Stretch" Command="{Binding SetValueCommand}" CommandParameter="6"/>

            <Button Grid.Row="2" Grid.Column="0" Content="7" HorizontalAlignment="Stretch" Command="{Binding SetValueCommand}" CommandParameter="7"/>
            <Button Grid.Row="2" Grid.Column="1" Content="8" HorizontalAlignment="Stretch" Command="{Binding SetValueCommand}" CommandParameter="8"/>
            <Button Grid.Row="2" Grid.Column="2" Content="9" HorizontalAlignment="Stretch" Command="{Binding SetValueCommand}" CommandParameter="9"/>
        </Grid>

        <!-- Action Buttons -->
        <StackPanel Orientation="Horizontal" Spacing="4">
            <Button
                Content="Clear"
                HorizontalAlignment="Stretch"
                Command="{Binding SetValueCommand}"
                CommandParameter="0"/>
            <ToggleButton
                Content="Notes"
                HorizontalAlignment="Stretch"
                x:Name="NotesToggleButton"/>
        </StackPanel>
    </StackPanel>
</UserControl>
