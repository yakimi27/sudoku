<?xml version=1.0 encoding=utf-8?>
<Page
    x:Class=Sudoku.Presentation.Views.Pages.ProfilePage
    xmlns=http://schemas.microsoft.com/winfx/2006/xaml/presentation
    xmlns:x=http://schemas.microsoft.com/winfx/2006/xaml>

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source=ms-appx:///Presentation/Resources/Styles/Typography.xaml/>
                <ResourceDictionary Source=ms-appx:///Presentation/Resources/Styles/ButtonStyles.xaml/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background={ThemeResource SudokuBackgroundBrush} Padding=20>
        <StackPanel Orientation=Vertical Spacing=20 MaxWidth=600>
            <!-- Header -->
            <TextBlock
                x:Uid=ProfilePage_Title
                Text=Player Profile
                Style={StaticResource PageTitleStyle}/>

            <!-- Avatar Section -->
            <StackPanel Orientation=Vertical Spacing=10>
                <TextBlock
                    x:Uid=ProfilePage_AvatarLabel
                    Text=Avatar
                    Style={StaticResource SectionHeaderStyle}/>
                <GridView
                    x:Name=AvatarGrid
                    SelectionMode=Single
                    SelectedIndex={Binding AvatarIndex, Mode=TwoWay}
                    ItemsSource={Binding AvailableAvatars}>
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Image Width=60 Height=60 Source={Binding}/>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </StackPanel>

            <!-- Player Name Section -->
            <StackPanel Orientation=Vertical Spacing=8>
                <TextBlock
                    x:Uid=ProfilePage_PlayerNameLabel
                    Text=Player Name
                    Style={StaticResource LabelTextStyle}/>
                <TextBox
                    Text={Binding PlayerName, Mode=TwoWay}
                    x:Uid=ProfilePage_PlayerNamePlaceholder
                    PlaceholderText=Enter your name
                    Padding=12,8/>
            </StackPanel>

            <!-- Player Stats (Read-only) -->
            <StackPanel Orientation=Vertical Spacing=8>
                <TextBlock
                    x:Uid=ProfilePage_StatisticsLabel
                    Text=Statistics
                    Style={StaticResource SectionHeaderStyle}/>
                <StackPanel Orientation=Vertical Spacing=4 Padding=12 Background={ThemeResource SudokuSurfaceBrush} CornerRadius=8 BorderBrush={ThemeResource SudokuBorderBrush} BorderThickness=1>
                    <StackPanel Orientation=Horizontal Spacing=10>
                        <TextBlock x:Uid=ProfilePage_LevelLabel Text=Level: Style={StaticResource StatLabelStyle}/>
                        <TextBlock Text={Binding Level} Style={StaticResource StatValueStyle}/>
                    </StackPanel>
                    <StackPanel Orientation=Horizontal Spacing=10>
                        <TextBlock x:Uid=ProfilePage_ExperienceLabel Text=Experience Points: Style={StaticResource StatLabelStyle}/>
                        <TextBlock Text={Binding ExperiencePoints} Style={StaticResource StatValueStyle}/>
                    </StackPanel>
                    <StackPanel Orientation=Horizontal Spacing=10>
                        <TextBlock x:Uid=ProfilePage_AchievementsLabel Text=Achievements: Style={StaticResource StatLabelStyle}/>
                        <TextBlock Text={Binding AchievementsCount} Style={StaticResource StatValueStyle}/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <!-- Save Button -->
            <Button
                x:Uid=ProfilePage_SaveButton
                Content=Save Changes
                Style={StaticResource PrimaryActionButtonStyle}
                HorizontalAlignment=Stretch
                Command={Binding SaveProfileCommand}
                Padding=12/>
        </StackPanel>
    </Grid>
</Page>
