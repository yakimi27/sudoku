<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Sudoku.Presentation.Views.Pages.ProfilePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="Transparent" Padding="20">
        <StackPanel Orientation="Vertical" Spacing="20" MaxWidth="400">
            <!-- Header -->
            <TextBlock
                Text="Player Profile"
                FontSize="32"
                FontWeight="Bold"/>

            <!-- Avatar Section -->
            <StackPanel Orientation="Vertical" Spacing="10">
                <TextBlock Text="Avatar" FontSize="16" FontWeight="SemiBold"/>
                <GridView
                    x:Name="AvatarGrid"
                    SelectionMode="Single"
                    SelectedIndex="{Binding AvatarIndex, Mode=TwoWay}"
                    ItemsSource="{Binding AvailableAvatars}">
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Image Width="60" Height="60" Source="{Binding}"/>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </StackPanel>

            <!-- Player Name Section -->
            <StackPanel Orientation="Vertical" Spacing="8">
                <TextBlock Text="Player Name" FontSize="16" FontWeight="SemiBold"/>
                <TextBox
                    Text="{Binding PlayerName, Mode=TwoWay}"
                    PlaceholderText="Enter your name"
                    Padding="12,8"/>
            </StackPanel>

            <!-- Player Stats (Read-only) -->
            <StackPanel Orientation="Vertical" Spacing="8">
                <TextBlock Text="Statistics" FontSize="16" FontWeight="SemiBold"/>
                <StackPanel Orientation="Vertical" Spacing="4">
                    <TextBlock>
                        <Run Text="Level: "/>
                        <Run Text="{Binding Level}" FontWeight="SemiBold"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="Experience Points: "/>
                        <Run Text="{Binding ExperiencePoints}" FontWeight="SemiBold"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="Achievements: "/>
                        <Run Text="{Binding AchievementsCount}" FontWeight="SemiBold"/>
                    </TextBlock>
                </StackPanel>
            </StackPanel>

            <!-- Save Button -->
            <Button
                Content="Save Changes"
                HorizontalAlignment="Stretch"
                Command="{Binding SaveProfileCommand}"
                Padding="12"/>
        </StackPanel>
    </Grid>
</Page>
