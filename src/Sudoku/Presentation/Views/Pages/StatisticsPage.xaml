<?xml version=1.0 encoding=utf-8?>
<Page
    x:Class=Sudoku.Presentation.Views.Pages.StatisticsPage
    xmlns=http://schemas.microsoft.com/winfx/2006/xaml/presentation
    xmlns:x=http://schemas.microsoft.com/winfx/2006/xaml>

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source=ms-appx:///Presentation/Resources/Styles/Typography.xaml/>
                <ResourceDictionary Source=ms-appx:///Presentation/Resources/Styles/ButtonStyles.xaml/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background={ThemeResource SudokuBackgroundBrush} Padding=20>
        <StackPanel Orientation=Vertical Spacing=20>
            <!-- Header -->
            <TextBlock
                x:Uid=StatisticsPage_Title
                Text=Game Statistics
                Style={StaticResource PageTitleStyle}/>

            <!-- Stats Summary -->
            <StackPanel Orientation=Horizontal Spacing=40>
                <StackPanel Orientation=Vertical>
                    <TextBlock
                        x:Uid=StatisticsPage_TotalGamesLabel
                        Text=Total Games Completed
                        Foreground={ThemeResource SudokuTextSecondaryBrush}
                        FontSize=14/>
                    <TextBlock
                        Text={Binding TotalGamesCompleted}
                        Style={StaticResource StatValueStyle}/>
                </StackPanel>
            </StackPanel>

            <!-- Statistics Content -->
            <TextBlock
                Text={Binding StatisticsData}
                Style={StaticResource BodyTextStyle}/>

            <!-- Actions -->
            <StackPanel Orientation=Horizontal Spacing=10>
                <Button
                    x:Uid=StatisticsPage_LoadButton
                    Content=Load Statistics
                    Style={StaticResource ActionButtonStyle}
                    Command={Binding LoadStatisticsCommand}/>
                <Button
                    x:Uid=StatisticsPage_ResetButton
                    Content=Reset Statistics
                    Style={StaticResource DangerActionButtonStyle}
                    Command={Binding ResetStatisticsCommand}/>
            </StackPanel>

            <!-- Reset Confirmation -->
            <Border
                Background={ThemeResource WarningBrush}
                CornerRadius=8
                Padding=15
                Visibility={Binding ShowResetConfirmation, Converter={StaticResource BoolToVisibilityConverter}}>
                <StackPanel Orientation=Vertical Spacing=10>
                    <TextBlock
                        x:Uid=StatisticsPage_ResetConfirmation
                        Text=Are you sure you want to reset all statistics? This cannot be undone.
                        Style={StaticResource BodyTextStyle}/>
                    <StackPanel Orientation=Horizontal Spacing=10>
                        <Button
                            x:Uid=StatisticsPage_ConfirmResetButton
                            Content=Yes, Reset
                            Style={StaticResource DangerActionButtonStyle}
                            Command={Binding ConfirmResetCommand}/>
                        <Button
                            x:Uid=StatisticsPage_CancelButton
                            Content=Cancel
                            Style={StaticResource SecondaryButtonStyle}
                            Command={Binding CancelResetCommand}/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>
