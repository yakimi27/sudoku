<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Sudoku.Presentation.Views.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="Transparent" Padding="20">
        <StackPanel Orientation="Vertical" Spacing="30" MaxWidth="400">
            <!-- Header -->
            <TextBlock
                Text="Settings"
                FontSize="32"
                FontWeight="Bold"/>

            <!-- Theme Settings -->
            <StackPanel Orientation="Vertical" Spacing="12">
                <TextBlock Text="Appearance" FontSize="18" FontWeight="SemiBold"/>
                <StackPanel Orientation="Vertical" Spacing="8" Padding="12" Background="#F0F0F0" CornerRadius="8">
                    <TextBlock Text="Theme" FontSize="14"/>
                    <ComboBox
                        ItemsSource="{Binding AvailableThemes}"
                        SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                        Width="200"
                        HorizontalAlignment="Left"/>
                </StackPanel>
            </StackPanel>

            <!-- Language Settings -->
            <StackPanel Orientation="Vertical" Spacing="12">
                <TextBlock Text="Language" FontSize="18" FontWeight="SemiBold"/>
                <StackPanel Orientation="Vertical" Spacing="8" Padding="12" Background="#F0F0F0" CornerRadius="8">
                    <TextBlock Text="Interface Language" FontSize="14"/>
                    <ComboBox
                        ItemsSource="{Binding AvailableLanguages}"
                        SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                        Width="200"
                        HorizontalAlignment="Left"/>
                </StackPanel>
            </StackPanel>

            <!-- Game Settings -->
            <StackPanel Orientation="Vertical" Spacing="12">
                <TextBlock Text="Gameplay" FontSize="18" FontWeight="SemiBold"/>
                <StackPanel Orientation="Vertical" Spacing="8" Padding="12" Background="#F0F0F0" CornerRadius="8">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Show Hints" FontSize="14" VerticalAlignment="Center"/>
                        <ToggleSwitch/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Sound Effects" FontSize="14" VerticalAlignment="Center"/>
                        <ToggleSwitch/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
