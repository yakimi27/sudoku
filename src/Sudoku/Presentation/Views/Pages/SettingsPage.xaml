<?xml version=1.0 encoding=utf-8?>
<Page
    x:Class=Sudoku.Presentation.Views.Pages.SettingsPage
    xmlns=http://schemas.microsoft.com/winfx/2006/xaml/presentation
    xmlns:x=http://schemas.microsoft.com/winfx/2006/xaml>

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source=ms-appx:///Presentation/Resources/Styles/Typography.xaml/>
                <ResourceDictionary Source=ms-appx:///Presentation/Resources/Styles/ButtonStyles.xaml/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background={ThemeResource SudokuBackgroundBrush} Padding=20>
        <StackPanel Orientation=Vertical Spacing=30 MaxWidth=600>
            <!-- Header -->
            <TextBlock
                x:Uid=SettingsPage_Title
                Text=Settings
                Style={StaticResource PageTitleStyle}/>

            <!-- Theme Settings -->
            <StackPanel Orientation=Vertical Spacing=12>
                <TextBlock
                    x:Uid=SettingsPage_AppearanceLabel
                    Text=Appearance
                    Style={StaticResource SectionHeaderStyle}/>
                <StackPanel Orientation=Vertical Spacing=8 Padding=12 Background={ThemeResource SudokuSurfaceBrush} CornerRadius=8 BorderBrush={ThemeResource SudokuBorderBrush} BorderThickness=1>
                    <TextBlock
                        x:Uid=SettingsPage_ThemeLabel
                        Text=Theme
                        Style={StaticResource LabelTextStyle}/>
                    <ComboBox
                        ItemsSource={Binding AvailableThemes}
                        SelectedItem={Binding SelectedTheme, Mode=TwoWay}
                        Width=250
                        HorizontalAlignment=Left/>
                </StackPanel>
            </StackPanel>

            <!-- Language Settings -->
            <StackPanel Orientation=Vertical Spacing=12>
                <TextBlock
                    x:Uid=SettingsPage_LanguageLabel
                    Text=Language
                    Style={StaticResource SectionHeaderStyle}/>
                <StackPanel Orientation=Vertical Spacing=8 Padding=12 Background={ThemeResource SudokuSurfaceBrush} CornerRadius=8 BorderBrush={ThemeResource SudokuBorderBrush} BorderThickness=1>
                    <TextBlock
                        x:Uid=SettingsPage_InterfaceLanguageLabel
                        Text=Interface Language
                        Style={StaticResource LabelTextStyle}/>
                    <ComboBox
                        ItemsSource={Binding AvailableLanguages}
                        SelectedItem={Binding SelectedLanguage, Mode=TwoWay}
                        Width=250
                        HorizontalAlignment=Left/>
                </StackPanel>
            </StackPanel>

            <!-- Game Settings -->
            <StackPanel Orientation=Vertical Spacing=12>
                <TextBlock
                    x:Uid=SettingsPage_GameplayLabel
                    Text=Gameplay
                    Style={StaticResource SectionHeaderStyle}/>
                <StackPanel Orientation=Vertical Spacing=8 Padding=12 Background={ThemeResource SudokuSurfaceBrush} CornerRadius=8 BorderBrush={ThemeResource SudokuBorderBrush} BorderThickness=1>
                    <StackPanel Orientation=Horizontal Spacing=10>
                        <TextBlock
                            x:Uid=SettingsPage_ShowHintsLabel
                            Text=Show Hints
                            Style={StaticResource LabelTextStyle}
                            VerticalAlignment=Center/>
                        <ToggleSwitch/>
                    </StackPanel>
                    <StackPanel Orientation=Horizontal Spacing=10>
                        <TextBlock
                            x:Uid=SettingsPage_SoundEffectsLabel
                            Text=Sound Effects
                            Style={StaticResource LabelTextStyle}
                            VerticalAlignment=Center/>
                        <ToggleSwitch/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
