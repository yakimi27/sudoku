<?xml version=1.0 encoding=utf-8?>
<Page
    x:Class=Sudoku.Presentation.Views.Pages.MenuPage
    xmlns=http://schemas.microsoft.com/winfx/2006/xaml/presentation
    xmlns:x=http://schemas.microsoft.com/winfx/2006/xaml>

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source=ms-appx:///Presentation/Resources/Styles/Typography.xaml/>
                <ResourceDictionary Source=ms-appx:///Presentation/Resources/Styles/ButtonStyles.xaml/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <Grid Background={ThemeResource SudokuBackgroundBrush}>
        <StackPanel
            Orientation=Vertical
            VerticalAlignment=Center
            HorizontalAlignment=Center
            Spacing=20>

            <!-- Hero Section -->
            <TextBlock
                x:Uid=MenuPage_Title
                Text=Sudoku
                Style={StaticResource GameTitleStyle}/>

            <TextBlock
                x:Uid=MenuPage_Subtitle
                Text=Challenge Your Mind
                Style={StaticResource BodyTextStyle}
                TextAlignment=Center
                FontSize=20/>

            <!-- Daily Challenge Card -->
            <Border
                Background={ThemeResource SudokuSurfaceBrush}
                CornerRadius=8
                Padding=20
                Width=300
                HorizontalAlignment=Center
                BorderBrush={ThemeResource SudokuBorderBrush}
                BorderThickness=1>
                <StackPanel Orientation=Vertical Spacing=10>
                    <TextBlock
                        x:Uid=MenuPage_DailyChallengeLabel
                        Text=Daily Challenge
                        Style={StaticResource SectionHeaderStyle}/>
                    <TextBlock
                        x:Name=DailyChallengeText
                        Text=Medium Difficulty
                        Style={StaticResource BodyTextStyle}/>
                    <Button
                        x:Uid=MenuPage_PlayDailyButton
                        Content=Play Daily Challenge
                        Style={StaticResource ActionButtonStyle}
                        HorizontalAlignment=Stretch/>
                </StackPanel>
            </Border>

            <!-- Main Buttons -->
            <StackPanel Orientation=Vertical Spacing=10 Width=300>
                <Button
                    x:Uid=MenuPage_StartNewGameButton
                    Content=Start New Game
                    Style={StaticResource ActionButtonStyle}
                    HorizontalAlignment=Stretch
                    Command={Binding StartGameCommand}/>

                <Button
                    x:Uid=MenuPage_ContinueGameButton
                    Content=Continue Game
                    Style={StaticResource SecondaryButtonStyle}
                    HorizontalAlignment=Stretch
                    Command={Binding ContinueGameCommand}/>

                <Button
                    x:Uid=MenuPage_ViewStatisticsButton
                    Content=View Statistics
                    Style={StaticResource SecondaryButtonStyle}
                    HorizontalAlignment=Stretch
                    Command={Binding ViewStatisticsCommand}/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
